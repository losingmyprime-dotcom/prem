local function getTapButton()
	local gui = PlayerGui:FindFirstChild("MinigameGui")
	if not gui then return nil end
	local games = gui:FindFirstChild("Games")
	if not games then return nil end
	local popcorn = games:FindFirstChild("PopcornBurstGui")
	if not popcorn then return nil end
	local holder = popcorn:FindFirstChild("Holder")
	if not holder then return nil end
	for _, v in ipairs(holder:GetChildren()) do
		if v:IsA("TextButton") then return v end
	end
	return nil
end

local function getShrinkingFrame(btn)
	local largest, maxScale = nil, 0
	for _, child in ipairs(btn:GetChildren()) do
		if child:IsA("Frame") then
			local sx = child.Size.X.Scale
			if sx > maxScale then
				maxScale = sx
				largest = child
			end
		end
	end
	return largest
end

