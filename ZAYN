	Header.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
			or i.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = i.Position
			startPos = Panel.Position
		end
	end)

	UserInputService.InputChanged:Connect(function(i)
		if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement
			or i.UserInputType == Enum.UserInputType.Touch) then
			local d = i.Position - dragStart
			Panel.Position = UDim2.fromOffset(startPos.X.Offset + d.X, startPos.Y.Offset + d.Y)
		end
	end)

	UserInputService.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
			or i.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	local pingTick = 0
	pingLoop = RunService.Heartbeat:Connect(function()
		pingTick = pingTick + 1
		if pingTick >= 20 then
			pingTick = 0
			local ms = math.round(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
			local color
			if ms < 80 then
				color = Color3.fromRGB(0, 210, 80)
			elseif ms < 150 then
				color = Color3.fromRGB(240, 185, 40)
			else
				color = Color3.fromRGB(210, 55, 55)
			end
			PingVal.Text = ms .. " ms"
			PingVal.TextColor3 = color
		end
	end)

	local function setAuto(on)
		autoTapEnabled = on
		if mainLoop then mainLoop:Disconnect(); mainLoop = nil end

		if on then
			lastRing = nil
			fired = false
			tapCount = 0
			TapVal.Text = "0"
			Btn.Text = "Stop"
			Btn.BackgroundColor3 = Color3.fromRGB(175, 32, 32)
			Dot.BackgroundColor3 = Color3.fromRGB(0, 210, 80)
			StatusVal.Text = "Running"
			StatusVal.TextColor3 = Color3.fromRGB(0, 210, 80)

			mainLoop = RunService.Heartbeat:Connect(function()
				if not autoTapEnabled then return end

				local tapBtn = getTapButton()
				if not tapBtn then
					RingVal.Text = "waiting..."
					RingVal.TextColor3 = Color3.fromRGB(130, 138, 155)
					lastRing = nil
					fired = false
					return
				end

				local ring = getShrinkingFrame(tapBtn)
				if not ring then
					RingVal.Text = "pending..."
					RingVal.TextColor3 = Color3.fromRGB(150, 158, 172)
					lastRing = nil
					fired = false
					return
				end

				local scale = ring.Size.X.Scale
				RingVal.Text = string.format("%.3f", scale)
				RingVal.TextColor3 = Color3.fromRGB(220, 225, 235)

				if ring ~= lastRing then
					lastRing = ring
					fired = false
				end

				if not fired and scale <= 0.45 then
					fired = true
					Remote:FireServer("AttemptPop", workspace:GetServerTimeNow())
					tapCount = tapCount + 1
					TapVal.Text = tostring(tapCount)
					TapVal.TextColor3 = Color3.fromRGB(0, 210, 80)
					RingVal.TextColor3 = Color3.fromRGB(0, 210, 80)
					task.delay(0.4, function()
						if autoTapEnabled then
							TapVal.TextColor3 = Color3.fromRGB(220, 225, 235)
							RingVal.TextColor3 = Color3.fromRGB(220, 225, 235)
						end
					end)
				end
			end)
		else
			Btn.Text = "Start"
			Btn.BackgroundColor3 = Color3.fromRGB(0, 168, 65)
			Dot.BackgroundColor3 = Color3.fromRGB(80, 88, 105)
			StatusVal.Text = "Idle"
			StatusVal.TextColor3 = Color3.fromRGB(220, 225, 235)
			RingVal.Text = "--"
			RingVal.TextColor3 = Color3.fromRGB(220, 225, 235)
			TapVal.Text = "0"
			TapVal.TextColor3 = Color3.fromRGB(220, 225, 235)
		end
	end

	Btn.MouseButton1Click:Connect(function()
		setAuto(not autoTapEnabled)
	end)
end

local function destroyGui()
	if mainLoop then mainLoop:Disconnect(); mainLoop = nil end
	if pingLoop then pingLoop:Disconnect(); pingLoop = nil end
	autoTapEnabled = false
	local existing = PlayerGui:FindFirstChild("PopcornAutoTapGui")
	if existing then existing:Destroy() end
end

