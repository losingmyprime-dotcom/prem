local function findNearestArenaBrainrot(fromPos)
	local af=Workspace:FindFirstChild("ArenaBrainrots")
	if not af then return nil,nil end
	local candidates={}
	for _,child in ipairs(af:GetChildren()) do
		if child.Name=="RenderedBrainrot" then
			local pos=getModelPos(child)
			if pos then
				local name=getBrainrotName(child)
				local rarity=getBrainrotRarity(name)
				local prio=RARITY_PRIORITY[rarity] or 999
				local dist=(Vector3.new(pos.X,0,pos.Z)-Vector3.new(fromPos.X,0,fromPos.Z)).Magnitude
				table.insert(candidates,{obj=child,pos=pos,prio=prio,dist=dist,rarity=rarity,name=name})
			end
		end
	end
	if #candidates==0 then return nil,nil end
	if next(A_TARGET_RARITIES)~=nil then
		local filtered={}
		for _,c in ipairs(candidates) do
			if A_TARGET_RARITIES[c.rarity] then table.insert(filtered,c) end
		end
		if #filtered==0 then return nil,nil end
		candidates=filtered
	end
	table.sort(candidates,function(a,b)
		if a.prio~=b.prio then return a.prio<b.prio end
		return a.dist<b.dist
	end)
	local best=candidates[1]
	return best.obj,best.pos
end

local function isBrainrotGone(target)
	if not target then return true end
	if not target.Parent then return true end
	local af=Workspace:FindFirstChild("ArenaBrainrots")
	if not af then return true end
	return not target:IsDescendantOf(af)
end

-- Poll runs every single Heartbeat (no throttle) for fastest detection.
local function startArenaPoll()
	if A.pollConn then A.pollConn:Disconnect() end
	A.pollConn=RunService.Heartbeat:Connect(function()
		if A.pollTarget then
			if isBrainrotGone(A.pollTarget) then
				A.pollTargetGone=true
				A.pollTarget=nil; A.pollTargetPos=nil; A.pollHasTarget=false
				return
			end
		end
		local root=getRoot()
		if not root then A.pollHasTarget=false; return end
		local obj,pos=findNearestArenaBrainrot(root.Position)
		if obj and pos then
			A.pollTarget=obj; A.pollTargetPos=pos; A.pollHasTarget=true
		else
			A.pollTarget=nil; A.pollTargetPos=nil; A.pollHasTarget=false
		end
	end)
end

local function getTakePrompt(target)
	if not target or not target.Parent then return {} end
	local prompts={}; local seen={}
	local function addPrompt(p)
		if p and p:IsA("ProximityPrompt") and not seen[p] then seen[p]=true; prompts[#prompts+1]=p end
	end
	pcall(function()
		local ro=target:FindFirstChild("Root")
		if ro then local tp=ro:FindFirstChild("TakePrompt"); if tp then addPrompt(tp) end end
	end)
	if #prompts==0 then local tp=target:FindFirstChild("TakePrompt",true); if tp then addPrompt(tp) end end
	if #prompts==0 then for _,d in ipairs(target:GetDescendants()) do addPrompt(d) end end
	return prompts
end

local function doPickupNormal(target, checkFn)
	if isBrainrotGone(target) then return true end
	if hasBrainrotEquipped() then return true end

	local prompts=getTakePrompt(target)

	local stickConn=RunService.Heartbeat:Connect(function()
		for _,p in ipairs(prompts) do
			if p and p.Parent then
				p.HoldDuration=0; p.Enabled=true; p.MaxActivationDistance=50
			end
		end
		local lp=getLivePos(); local root=getRoot()
		if lp and root then
			local cur=root.Position
			local dest=Vector3.new(lp.X,cur.Y,lp.Z)
			local dist=(dest-cur).Magnitude
			if dist>1.5 then
				local dir=(dest-cur).Unit; local step=math.min(dist,8)
				pcall(function()
					root.CFrame=CFrame.new(cur+dir*step,
						cur+dir*step+(Workspace.CurrentCamera and Workspace.CurrentCamera.CFrame.LookVector or Vector3.new(0,0,-1)))
				end)
			end
		end
	end)

	do
		local spawnSurfaceY=getBrainrotSpawnSurfaceY()
		if spawnSurfaceY then
			local r2=getRoot(); local hum=getHumanoid()
			if r2 and hum then
				local snapY=spawnSurfaceY+getHeadOffset()
				local lp=getLivePos()
				if lp then
					hum.PlatformStand=true; createBV(r2)
					flyToPos(Vector3.new(lp.X,snapY,lp.Z), A.flySpeed, checkFn)
					destroyBV(); hum.PlatformStand=false
				end
			end
		end
	end

	local success=false
	local timeout=tick()+15
	local VIS=game:GetService("VirtualInputManager")

	while checkFn() and tick()<timeout do
		if hasBrainrotEquipped() then success=true; break end
		if isBrainrotGone(target) then success=true; break end

		local freshPrompts=getTakePrompt(target)
		for _,p in ipairs(freshPrompts) do
			if p and p.Parent then
				p.HoldDuration=0; p.Enabled=true; p.MaxActivationDistance=50
				pcall(function()
					if type(fireproximityprompt)=="function" then
						fireproximityprompt(p); fireproximityprompt(p)
					else
						p:InputHoldBegin(); task.wait(0.01); p:InputHoldEnd()
					end
				end)
			end
		end
		pcall(function()
			if VIS then
				VIS:SendKeyEvent(true,Enum.KeyCode.E,false,game)
				VIS:SendKeyEvent(false,Enum.KeyCode.E,false,game)
			end
		end)

		RunService.Heartbeat:Wait()
		if hasBrainrotEquipped() then success=true; break end
		if isBrainrotGone(target) then success=true; break end
	end

	stickConn:Disconnect()
	for _,p in ipairs(prompts) do restorePromptDistance(p) end
	return success
end

local function isBrainrotBeforeCenter(fromPos, brainrotPos, center)
	if not center then return true end
	local distToBrainrot=(Vector3.new(brainrotPos.X,0,brainrotPos.Z)-Vector3.new(fromPos.X,0,fromPos.Z)).Magnitude
	local distToCenter=(Vector3.new(center.X,0,center.Z)-Vector3.new(fromPos.X,0,fromPos.Z)).Magnitude
	return distToBrainrot<=distToCenter
end

local function runModeNormal(target, targetPos, isRunning)
	local root=getRoot(); local hum=getHumanoid()
	if not root or not hum then return false end

	local center=getCenterPos()
	startBrainrotTracker(target)

	local lockedY=root.Position.Y
	A.lockedY=lockedY

	hum.PlatformStand=true; createBV(root)

	local skipCenter=isBrainrotBeforeCenter(root.Position,targetPos,center)
	if not skipCenter and center then
		flyToPos(Vector3.new(center.X,lockedY,center.Z), A.flySpeed, isRunning)
		if not isRunning() then stopBrainrotTracker(); destroyBV(); hum.PlatformStand=false; return false end
		if isBrainrotGone(target) then stopBrainrotTracker(); destroyBV(); hum.PlatformStand=false; return true end
	end

	flyToPos(function() return getLivePosAtY(lockedY) end, A.flySpeed, isRunning)
	if not isRunning() then stopBrainrotTracker(); destroyBV(); hum.PlatformStand=false; return false end
	if isBrainrotGone(target) then stopBrainrotTracker(); destroyBV(); hum.PlatformStand=false; return true end

	destroyBV(); hum.PlatformStand=false

	local picked=doPickupNormal(target, isRunning)
	stopBrainrotTracker()
	return picked
end

local function handleRespawn()
	destroyBV()
	local hum=getHumanoid(); if hum then hum.PlatformStand=false end
	anchorChar(false)
	local newChar=nil
	local charConn=player.CharacterAdded:Connect(function(c) newChar=c end)
	do
		local c=player.Character
		local h=c and c:FindFirstChildOfClass("Humanoid")
		if h and h.Health>0 then newChar=c end
	end
	local t0=tick()
	while not newChar and (tick()-t0<30) do RunService.Heartbeat:Wait() end
	charConn:Disconnect()
	task.wait(1)
	waitAlive()
end

local function arenaLoop(token)
	local function isRunning() return A.enabled and A.token==token end

	local isDead=false; local hbFrame=0
	local hbConn=RunService.Heartbeat:Connect(function()
		if isDead then return end
		hbFrame=hbFrame+1; if hbFrame<30 then return end; hbFrame=0
		local h=getHumanoid(); if not h or h.Health<=0 then isDead=true end
	end)

	waitAlive(); if not isRunning() then hbConn:Disconnect(); return end
	readFlySpeed()

	while isRunning() do

		if hasBrainrotEquipped() then
			goToBase()
			-- If goToBase returned because brainrot was dropped mid-flight,
			-- hasBrainrotEquipped() is now false and the next iteration will
			-- immediately poll and pick it back up — no extra wait needed.
			continue
		end

		if isDead then
			handleRespawn(); isDead=false; hbFrame=0
			if not isRunning() then break end
			local t0=tick()
			while tick()-t0<10 do
				if getRoot() then break end
				RunService.Heartbeat:Wait()
			end
		end

		local root=getRoot()
		if not root then RunService.Heartbeat:Wait(); continue end

		-- ============================================================
		-- NO TARGET — three phases, no teleportation anywhere
		-- ============================================================
		if not A.pollHasTarget then

			-- PHASE 1: completely still — wait until timer unlocks (≤1s)
			-- or a brainrot appears. No movement at all.
			while isRunning() and not A.pollHasTarget and not shouldGoToCenter() do
				RunService.Heartbeat:Wait()
			end
			if not isRunning() then break end
			if A.pollHasTarget then continue end   -- brainrot appeared, handle it

			-- PHASE 2: timer unlocked — fly smoothly to center.
			-- Stop flying the moment a brainrot is detected by the poll.
			local center=getCenterPos()
			if center then
				local hum=getHumanoid()
				local r=getRoot()
				if r and hum then
					local _surfY=getBrainrotSpawnSurfaceY()
					local groundY=_surfY and (_surfY+3) or A.START_POS.Y
					local distToCenter=(Vector3.new(center.X,0,center.Z)-Vector3.new(r.Position.X,0,r.Position.Z)).Magnitude
					if distToCenter>3 then
						hum.PlatformStand=true
						createBV(r)
						flyToPos(
							Vector3.new(center.X,groundY,center.Z),
							A.flySpeed,
							function() return isRunning() and not A.pollHasTarget end
						)
						destroyBV()
						hum.PlatformStand=false
					end
				end
			end
			if not isRunning() then break end
			if A.pollHasTarget then continue end   -- brainrot appeared mid-flight

			-- PHASE 3: at (or near) center, stand still and wait for a brainrot.
			-- No nudging, no CFrame writes at all.
			while isRunning() and not A.pollHasTarget do
				RunService.Heartbeat:Wait()
			end
			continue
		end
		-- ============================================================

		local target=A.pollTarget
		local targetPos=A.pollTargetPos
		if not target or not targetPos then continue end

		A.pollTargetGone=false

		local function isRunningAndAlive()
			return isRunning() and not A.pollTargetGone and not isDead
		end

		local picked=runModeNormal(target, targetPos, isRunningAndAlive)

		if not isRunning() then destroyBV(); break end
		if isDead then destroyBV(); continue end

		if A.pollTargetGone or picked then
			goToBase()
		end

		if not isRunning() then break end
		-- No task.wait here — let the loop spin freely for fastest response
	end

	hbConn:Disconnect()
	stopBrainrotTracker()
	anchorChar(false); destroyBV()
	local h2=getHumanoid(); if h2 then h2.PlatformStand=false end
	A.task=nil
end

