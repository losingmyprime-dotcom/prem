	btn.Size=UDim2.new(0,32,0,16)
	btn.Position=UDim2.new(1,-36,0.5,-8)
	btn.BackgroundColor3=Color3.fromRGB(30,30,30)
	Instance.new("UICorner",btn)

	local knob=Instance.new("Frame",btn)
	knob.Size=UDim2.new(0,12,0,12)
	knob.Position=UDim2.new(0,2,0.5,-6)
	knob.BackgroundColor3=Color3.new(1,1,1)
	Instance.new("UICorner",knob)

	local state = defaultState or false
	local function update()
		TweenService:Create(knob,TweenInfo.new(0.15),{
			Position=state and UDim2.new(1,-14,0.5,-6) or UDim2.new(0,2,0.5,-6)
		}):Play()
		btn.BackgroundColor3=state and C.ACCENT or Color3.fromRGB(30,30,30)
		if callback then callback(state) end
	end

	row.MouseEnter:Connect(function()
		TweenService:Create(row,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(15,15,15)}):Play()
	end)
	row.MouseLeave:Connect(function()
		TweenService:Create(row,TweenInfo.new(0.15),{BackgroundColor3=C.CARD}):Play()
	end)
	row.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
			state=not state; update()
		end
	end)
	if key ~= "" then
		UIS.InputBegan:Connect(function(i, gp)
			if not gp and i.KeyCode == Enum.KeyCode[key:upper()] then
				state = not state; update()
			end
		end)
	end
	update()

	local obj = {}
	function obj:SetState(newState)
		if state ~= newState then state = newState; update() end
	end
	return obj
end

local function addSlider(parent, text, minVal, maxVal, defaultVal, callback)
	local f=Instance.new("Frame",parent)
	f.Size=UDim2.new(1,0,0,45)
	f.BackgroundColor3=C.CARD
	f.BackgroundTransparency=0.1
	Instance.new("UICorner",f)

	local label=Instance.new("TextLabel",f)
	label.Text=text
	label.Position=UDim2.new(0,6,0,2)
	label.Size=UDim2.new(1,-40,0,18)
	label.TextColor3=C.TEXT
	label.BackgroundTransparency=1
	label.Font=Enum.Font.Gotham
	label.TextSize=11
	label.TextXAlignment=Enum.TextXAlignment.Left

	local val=Instance.new("TextLabel",f)
	val.Text=tostring(defaultVal)
	val.Position=UDim2.new(1,-30,0,2)
	val.Size=UDim2.new(0,30,0,18)
	val.TextColor3=C.ACCENT
	val.BackgroundTransparency=1
	val.Font=Enum.Font.GothamBold
	val.TextSize=11

	local bar=Instance.new("Frame",f)
	bar.Size=UDim2.new(1,-12,0,4)
	bar.Position=UDim2.new(0,6,0,28)
	bar.BackgroundColor3=Color3.fromRGB(30,30,30)
	Instance.new("UICorner",bar)

	local fill=Instance.new("Frame",bar)
	local pct=(defaultVal-minVal)/(maxVal-minVal)
	fill.Size=UDim2.new(pct,0,1,0)
	fill.BackgroundColor3=C.ACCENT
	Instance.new("UICorner",fill)

	local knob=Instance.new("Frame",bar)
	knob.Size=UDim2.new(0,10,0,10)
	knob.Position=UDim2.new(pct,-5,0.5,-5)
	knob.BackgroundColor3=Color3.new(1,1,1)
	Instance.new("UICorner",knob)

	local drag=false
	local function setValue(p)
		p=math.clamp(p,0,1)
		local cur=minVal+p*(maxVal-minVal)
		cur=math.floor(cur+0.5)
		local newPct=(cur-minVal)/(maxVal-minVal)
		fill.Size=UDim2.new(newPct,0,1,0)
		knob.Position=UDim2.new(newPct,-5,0.5,-5)
		val.Text=tostring(cur)
		if callback then callback(cur) end
	end

	bar.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
			drag=true
			local p=(i.Position.X-bar.AbsolutePosition.X)/bar.AbsoluteSize.X
			setValue(p)
		end
	end)
	UIS.InputEnded:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
			drag=false
		end
	end)
	UIS.InputChanged:Connect(function(i)
		if drag and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
			local p=(i.Position.X-bar.AbsolutePosition.X)/bar.AbsoluteSize.X
			setValue(p)
		end
	end)
	callback(defaultVal)
end

