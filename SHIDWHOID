local function getModelPos(obj)
	if not obj or not obj.Parent then return nil end
	local root=obj:FindFirstChild("Root")
	if root and root:IsA("BasePart") then return root.Position end
	local pos; pcall(function() pos=obj:GetPivot().Position end)
	if pos then return pos end
	for _,d in ipairs(obj:GetDescendants()) do
		if d:IsA("BasePart") then return d.Position end
	end
	if obj:IsA("BasePart") then return obj.Position end
	return nil
end

local function startBrainrotTracker(target)
	if A.trackerConn then A.trackerConn:Disconnect(); A.trackerConn=nil end
	A.trackedTarget=target
	A.trackedPos=getModelPos(target)
	if not target or not target.Parent then return end
	local rootPart=target:FindFirstChild("Root")
	A.trackerConn=RunService.Heartbeat:Connect(function()
		if not target or not target.Parent then
			if A.trackerConn then A.trackerConn:Disconnect(); A.trackerConn=nil end
			return
		end
		if rootPart and rootPart.Parent then A.trackedPos=rootPart.Position; return end
		pcall(function() A.trackedPos=target:GetPivot().Position end)
	end)
end

local function stopBrainrotTracker()
	if A.trackerConn then A.trackerConn:Disconnect(); A.trackerConn=nil end
	A.trackedTarget=nil; A.trackedPos=nil
end

local function getLivePos() return A.trackedPos end
