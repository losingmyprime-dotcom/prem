local function getBrainrotRarity(name)
	if not name then return nil end
	if brainrotRarityMap[name] then return brainrotRarityMap[name] end
	local af = Workspace:FindFirstChild("ArenaBrainrots")
	if not af then return nil end
	for _, child in ipairs(af:GetChildren()) do
		if child.Name == "RenderedBrainrot" then
			local bn = child:GetAttribute("BrainrotName") or child.Name
			if bn == name then
				local rar = child:GetAttribute("Rarity")
				if rar then return rar end
				return nil
			end
		end
	end
	return nil
end

local function fetchCenterPos()
	local go=Workspace:FindFirstChild("GameObjects")
	local ps=go and go:FindFirstChild("PlaceSpecific")
	local ar=ps and ps:FindFirstChild("tsunami_arena")
	local sp=ar and ar:FindFirstChild("BrainrotSpawn")
	if not sp then return nil end
	local pos
	pcall(function() pos=sp:GetPivot().Position end)
	if not pos then
		for _,d in ipairs(sp:GetDescendants()) do
			if d:IsA("BasePart") then pos=d.Position; break end
		end
		if not pos and sp:IsA("BasePart") then pos=sp.Position end
	end
	return pos
end

local function getBrainrotSpawnSurfaceY()
	local go=Workspace:FindFirstChild("GameObjects")
	local ps=go and go:FindFirstChild("PlaceSpecific")
	local ar=ps and ps:FindFirstChild("tsunami_arena")
	local sp=ar and ar:FindFirstChild("BrainrotSpawn")
	if not sp then return nil end
	local maxTopY=-math.huge; local found=false
	local function scanParts(obj)
		for _,d in ipairs(obj:GetDescendants()) do
			if d:IsA("BasePart") then
				local topY=d.Position.Y+d.Size.Y/2
				if topY>maxTopY then maxTopY=topY; found=true end
			end
		end
		if obj:IsA("BasePart") then
			local topY=obj.Position.Y+obj.Size.Y/2
			if topY>maxTopY then maxTopY=topY; found=true end
		end
	end
	pcall(scanParts, sp)
	if not found then
		pcall(function()
			local piv=sp:GetPivot().Position
			if piv then maxTopY=piv.Y; found=true end
		end)
	end
	return found and maxTopY or nil
end

local PLATFORM_Y    = -10
local PLATFORM_THICK= 5
local PLATFORM_HALF = 5000
local PLATFORM_SEG  = 2048

local function removePlatform()
	if A.platformNoclipConn then A.platformNoclipConn:Disconnect(); A.platformNoclipConn=nil end
	for _,p in ipairs(A.platformParts) do pcall(function() p:Destroy() end) end
	A.platformParts={}
end

local function buildPlatform(centerX, centerZ)
	removePlatform()
	local minX=centerX-PLATFORM_HALF; local maxX=centerX+PLATFORM_HALF
	local minZ=centerZ-PLATFORM_HALF; local maxZ=centerZ+PLATFORM_HALF
	local cursorX=minX
	while cursorX<maxX do
		local segW=math.min(PLATFORM_SEG,maxX-cursorX); local cursorZ=minZ
		while cursorZ<maxZ do
			local segD=math.min(PLATFORM_SEG,maxZ-cursorZ)
			local p=Instance.new("Part")
			p.Name="AutoArenaPlatform"; p.Anchored=true; p.CanCollide=true
			p.CanTouch=false; p.CanQuery=false
			p.Size=Vector3.new(segW,PLATFORM_THICK,segD)
			p.CFrame=CFrame.new(cursorX+segW/2,PLATFORM_Y,cursorZ+segD/2)
			p.Material=Enum.Material.SmoothPlastic; p.BrickColor=BrickColor.new("Bright red")
			p.Transparency=0.5; p.Locked=true; p.Parent=Workspace
			table.insert(A.platformParts,p)
			cursorZ=cursorZ+segD
		end
		cursorX=cursorX+segW
	end
	A.platformNoclipConn=RunService.Heartbeat:Connect(function()
		for _,p in ipairs(A.platformParts) do
			if p and p.Parent then p.CanCollide=true end
		end
	end)
end

local function setupPlatform()
	task.spawn(function()
		for i=1,15 do
			local pos=fetchCenterPos()
			if pos then A.centerPos=pos; buildPlatform(pos.X,pos.Z); return end
			task.wait(1)
		end
		buildPlatform(0,0)
	end)
end

