		return cachedBasePart
	end
	local basesFolder=Workspace:FindFirstChild("Bases")
	if not basesFolder then return nil end
	for _,folder in ipairs(basesFolder:GetChildren()) do
		if folder:GetAttribute("Holder")==player.UserId then
			local sp=folder:FindFirstChild("Spawn")
			if sp then cachedBasePart=sp; cachedBaseRefresh=now; return sp end
			for _,p in ipairs(folder:GetDescendants()) do
				if p:IsA("BasePart") then cachedBasePart=p; cachedBaseRefresh=now; return p end
			end
		end
	end
	return nil
end

local cachedLaneFloorCenter=nil

local function getNearestLaneFloorCenter()
	if cachedLaneFloorCenter then return cachedLaneFloorCenter end
	local basePart=getOwnBasePart()
	if not basePart then return nil end
	local basePos=basePart.Position
	local go=Workspace:FindFirstChild("GameObjects")
	local ps=go and go:FindFirstChild("PlaceSpecific")
	local ta=ps and ps:FindFirstChild("tsunami_arena")
	local lanes=ta and ta:FindFirstChild("Lanes")
	if not lanes then return nil end
	local bestCenter=nil; local bestDist=math.huge
	for _,lane in ipairs(lanes:GetChildren()) do
		for _,floor in ipairs(lane:GetChildren()) do
			if floor.Name=="Floor" and floor:IsA("BasePart") then
				local fp=floor.Position
				local dist=(Vector3.new(fp.X,0,fp.Z)-Vector3.new(basePos.X,0,basePos.Z)).Magnitude
				if dist<bestDist then
					bestDist=dist
					bestCenter=Vector3.new(fp.X,fp.Y+(floor.Size.Y/2),fp.Z)
				end
			end
		end
	end
	if bestCenter then cachedLaneFloorCenter=bestCenter end
	return bestCenter
end

local function handleWaveShield()
	local char=player.Character
	local bp=player:FindFirstChildOfClass("Backpack")
	if not char or not bp then return end
	local function hasCD(tool) return tool:FindFirstChild("CooldownHighlight",true)~=nil end
	for _,tool in ipairs(char:GetChildren()) do
		if tool:IsA("Tool") and tool:FindFirstChild("WaveShield") then
			if not hasCD(tool) then return end
		end
	end
	for _,tool in ipairs(bp:GetChildren()) do
		if tool:IsA("Tool") and tool:FindFirstChild("WaveShield") and not hasCD(tool) then
			local hum=char:FindFirstChildOfClass("Humanoid")
			if hum then hum:EquipTool(tool) end
			return
		end
	end
end

