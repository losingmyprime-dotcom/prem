end

local function goToBase()
	local basePart=getOwnBasePart()
	if not basePart then
		local root=getRoot()
		if root then pcall(function() root.CFrame=CFrame.new(A.START_POS) end) end
		return
	end

	local basePos=Vector3.new(basePart.Position.X, basePart.Position.Y+3, basePart.Position.Z)
	local root=getRoot()
	if not root then return end

	local hum=getHumanoid()
	if hum then hum.PlatformStand=true end
	createBV(root)

	local runRot=true
	local brainrotDropped=false

	local rotConn=RunService.Heartbeat:Connect(function()
		if runRot and hasBrainrotEquipped() then handleWaveShield() end
	end)

	local function flightCheck()
		if not runRot or not A.enabled then return false end
		if not hasBrainrotEquipped() then
			brainrotDropped=true
			return false
		end
		return true
	end

	local function cleanup()
		runRot=false
		rotConn:Disconnect()
		destroyBV()
		if hum then hum.PlatformStand=false end
	end

	local center=getCenterPos()
	if center then
		local groundY=A.START_POS.Y
		flyToPos(Vector3.new(center.X,groundY,center.Z), A.flySpeed, flightCheck)
	end
	if brainrotDropped then cleanup(); return end  

	flyToPos(basePos, A.flySpeed, flightCheck)
	if brainrotDropped then cleanup(); return end  

	
	local hrp2=getRoot()
	if hrp2 and basePart and basePart.Parent then
		pcall(function()
			firetouchinterest(hrp2,basePart,0)
			task.wait(0.05)
			firetouchinterest(hrp2,basePart,1)
		end)
	end

	-- Retry loop if brainrot is still equipped (needs lane-floor nudge)
	local retryCount=0
	while hasBrainrotEquipped() and A.enabled and retryCount<5 do
		retryCount=retryCount+1
		local floorCenter=getNearestLaneFloorCenter()
		if floorCenter then
			local floorDest=Vector3.new(floorCenter.X,floorCenter.Y+3,floorCenter.Z)
			flyToPos(floorDest, A.flySpeed, function() return runRot and A.enabled end)
			task.wait(0.1)
		end
		flyToPos(basePos, A.flySpeed, function() return runRot and A.enabled end)
		local hrp3=getRoot()
		if hrp3 and basePart and basePart.Parent then
			pcall(function()
				firetouchinterest(hrp3,basePart,0)
				task.wait(0.05)
				firetouchinterest(hrp3,basePart,1)
			end)
		end
	end

	cleanup()
end
