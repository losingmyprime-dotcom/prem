-- startTempel — also gated by shouldGoToCenter so it never
-- shoves the player toward center during the pre-start lobby.
-- ============================================================
local function startTempel()
	if A.tempelConn then A.tempelConn:Disconnect(); A.tempelConn=nil end
	A.tempelConn=RunService.Heartbeat:Connect(function()
		if not A.enabled then return end
		if A.pollHasTarget then return end
		-- KEY FIX: do not move during pre-start lobby
		if not shouldGoToCenter() then return end

		local function findPlayerWithBrainrot()
			for _,p in ipairs(Players:GetPlayers()) do
				if p==player then continue end
				local char=p.Character
				if char then
					for _,v in ipairs(char:GetChildren()) do
						if v:IsA("Model") and CollectionService:HasTag(v,"ArenaBrainrot") then return p end
					end
				end
				local pf=Workspace:FindFirstChild(p.Name)
				if pf and pf:FindFirstChild("RenderedBrainrot") then return p end
			end
			return nil
		end

		local playerWithBrainrot=findPlayerWithBrainrot()
		if playerWithBrainrot then
			local targetChar=playerWithBrainrot.Character
			local targetHRP=targetChar and targetChar:FindFirstChild("HumanoidRootPart")
			if not targetHRP then return end
			local myRoot=getRoot(); if not myRoot then return end
			local targetPos=targetHRP.Position; local myPos=myRoot.Position
			local dist=(Vector3.new(targetPos.X,0,targetPos.Z)-Vector3.new(myPos.X,0,myPos.Z)).Magnitude
			if dist>2 then
				local dir=(Vector3.new(targetPos.X,myPos.Y,targetPos.Z)-myPos)
				local step=math.min(dist,12)
				pcall(function()
					myRoot.CFrame=CFrame.new(
						myPos+dir.Unit*step,
						myPos+dir.Unit*step+(Workspace.CurrentCamera and Workspace.CurrentCamera.CFrame.LookVector or Vector3.new(0,0,-1))
					)
				end)
			end
		else
			local center=getCenterPos(); if not center then return end
			local myRoot=getRoot(); if not myRoot then return end
			local _surfY=getBrainrotSpawnSurfaceY()
			local groundY=_surfY and (_surfY+3) or A.START_POS.Y
			local dist=(Vector3.new(center.X,0,center.Z)-Vector3.new(myRoot.Position.X,0,myRoot.Position.Z)).Magnitude
			if dist>5 then
				local dest=Vector3.new(center.X,groundY,center.Z)
				local dir=(dest-myRoot.Position)
				local step=math.min(dist,12)
				pcall(function()
					myRoot.CFrame=CFrame.new(
						myRoot.Position+dir.Unit*step,
						myRoot.Position+dir.Unit*step+(Workspace.CurrentCamera and Workspace.CurrentCamera.CFrame.LookVector or Vector3.new(0,0,-1))
					)
				end)
			end
		end
	end)
end

