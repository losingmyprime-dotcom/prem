local function clamp(v,mn,mx) return math.max(mn,math.min(mx,v)) end

local function flyToPos(targetPos, speed, checkFn)
	local root=getRoot(); if not root then return false end
	speed=clamp(speed or A.flySpeed,1,5000)
	local isLive=type(targetPos)=="function"
	while checkFn and checkFn() do
		root=getRoot(); if not root then break end
		local dest=isLive and targetPos() or targetPos
		if dest==nil then break end
		local cur=root.Position; local dir=dest-cur; local dist=dir.Magnitude
		if dist<=0.5 then return true end
		local dt=RunService.Heartbeat:Wait()
		local step=dir.Unit*math.min(speed*dt,dist)
		pcall(function() if root.AssemblyLinearVelocity then root.AssemblyLinearVelocity=Vector3.zero end end)
		local look=Workspace.CurrentCamera and Workspace.CurrentCamera.CFrame.LookVector or Vector3.new(0,0,-1)
		root.CFrame=CFrame.new(cur+step,cur+step+look)
	end
	return false
end

