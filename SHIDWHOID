local function getArenaTimerData()
	local pg=player.PlayerGui
	local ta=pg and pg:FindFirstChild("TsunamiArena")
	if not ta then return nil, nil end
	local mt=ta:FindFirstChild("MatchTimer")

	if not mt then return nil, nil end
